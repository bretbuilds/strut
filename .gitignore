# =============================================================================
# Universal (applies to any stack)
# =============================================================================

# Environment variables
.env
.env.*
!.env.example

# OS
**/.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# General logs
*.log

# Coverage (most test runners write here; adjust if yours differs)
coverage/

# =============================================================================
# STRUT
# =============================================================================

# Pipeline working state — ephemeral, rewritten every run, never source
.pipeline/

# Local test run transcripts — generated by docs/contributing/testing/run-tests.sh
docs/contributing/testing/results/

# Local Claude Code settings — personal overrides, may contain MCP secrets
.claude/settings.local.json

# Everything else under .claude/ is source: rules/, skills/, agents/, settings.json
# Archived specs under .specs/ are historical record — commit them.

# =============================================================================
# Stack-specific
# =============================================================================
# TODO: Uncomment and adapt the block matching your stack, or add your own.
# Examples below; delete the ones you don't use.

# --- Node / npm / yarn / pnpm ---
node_modules/
# .pnp
# .pnp.js
# .next/
# out/
# dist/
# build/
# *.tsbuildinfo
# npm-debug.log*
# yarn-debug.log*
# yarn-error.log*
# pnpm-debug.log*

# --- Python ---
# __pycache__/
# *.py[cod]
# *$py.class
# .pytest_cache/
# .mypy_cache/
# .ruff_cache/
# .venv/
# venv/
# dist/
# build/
# *.egg-info/

# --- Rust ---
# target/
# Cargo.lock  # (commit for binaries, gitignore for libraries — adjust per project)

# --- Go ---
# vendor/
# *.exe
# *.test
# *.out
